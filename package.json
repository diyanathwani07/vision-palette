{
  "name": "vision-palette-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix ui-frontend",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix ui-frontend",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --prefix ui-frontend",
    "start": "npm run start --prefix server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
